generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 1. Gestion des Utilisateurs et Profils
model User {
  id            String    @id @default(cuid())
  pseudo        String    @unique // Pour être identifiable [cite: 3]
  photoUrl      String?   // Photo de profil [cite: 3, 5]
  bio           String?   // Bio utilisateur [cite: 6]
  createdAt     DateTime  @default(now())
  
  coverUrl      String?   // Image de bannière de profil
  spotifyId     String?   // Pour import de playlists
  totalListeningTime Int @default(0) // En secondes

  // Relations
  ownedJams     JamSession[] @relation("HostRelation")
  tracksAdded   Track[]      @relation("UserTracks")
  bannedFrom    BannedUser[] @relation("UserBans")
  participations JamParticipation[] @relation("UserParticipations")
  messages      Message[]    @relation("UserMessages")
  friends1      Friend[]     @relation("UserFriends1")
  friends2      Friend[]     @relation("UserFriends2")
}

// 2. Gestion de la Session de Jam
model JamSession {
  id            String    @id @default(cuid())
  sessionId     String    @unique // Format "JAM-8821" [cite: 28, 88]
  isActive      Boolean   @default(true) // Statut "LIVE SESSION" [cite: 25, 82]
  createdAt     DateTime  @default(now())
  
  // Nouvelles métadonnées (V2)
  isPublic      Boolean   @default(true)
  name          String?
  genre         String?
  listenerCount Int       @default(0)
  coverUrl      String?

  // Paramètres de Permissions (Sprint 1 & 2)
  votingEnabled Boolean   @default(true)  // [cite: 31, 100]
  guestUploads  Boolean   @default(false) // [cite: 33, 106]
  explicitFilter Boolean  @default(false) // [cite: 35]
  approvalRequired Boolean @default(false)
  isAnonymous   Boolean   @default(false) // Anonymous Music Mode

  currentTrackStartTime DateTime? // Time the track started for sync
  pausedAt      DateTime? // The exact time the track was paused
  isPaused      Boolean   @default(false) // Is the current track paused
  
  // Relations
  hostId        String
  host          User      @relation("HostRelation", fields: [hostId], references: [id])
  queue         Track[]   @relation("SessionQueue")
  bannedUsers   BannedUser[] @relation("SessionBans")
  messages      Message[]    @relation("SessionMessages")
  participations JamParticipation[] @relation("SessionParticipations")
}

// 4. Banned Users
model BannedUser {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("UserBans", fields: [userId], references: [id])
  sessionId     String
  session       JamSession @relation("SessionBans", fields: [sessionId], references: [id])
  bannedAt      DateTime  @default(now())

  @@unique([userId, sessionId])
}

// 3. File d'attente (Live Queue)
model Track {
  id            String    @id @default(cuid())
  title         String    // ex: "Midnight City" [cite: 15, 46, 116]
  artist        String    // ex: "M83" [cite: 16, 47, 97]
  album         String?   // [cite: 16, 49]
  thumbnail     String?   // Image du morceau
  sourceId      String    // ID YouTube ou Spotify [cite: 13, 14]
  platform      String    // "YOUTUBE", "SPOTIFY", etc. [cite: 44, 45]
  
  duration      Int?      // Durée en secondes [cite: 62]
  order         Int       @default(0) // Pour l'ordre de passage [cite: 60, 91]
  status        TrackStatus @default(QUEUED)
  isRevealed    Boolean   @default(false) // For Anonymous Music Mode
  
  // Relations
  sessionId     String
  session       JamSession @relation("SessionQueue", fields: [sessionId], references: [id], onDelete: Cascade)
  addedById     String
  addedBy       User       @relation("UserTracks", fields: [addedById], references: [id])
  
  createdAt     DateTime   @default(now())
}

enum TrackStatus {
  PLAYING  // "NOW PLAYING" [cite: 57, 89]
  QUEUED   // "Next up in the mix" [cite: 60, 91]
  PLAYED
  PENDING  // "Suggestion Mode" pending approval
}

// 5. Chat en Temps Réel
model Message {
  id            String    @id @default(cuid())
  content       String    // Max 500 chars
  sessionId     String
  session       JamSession @relation("SessionMessages", fields: [sessionId], references: [id], onDelete: Cascade)
  authorId      String
  author        User       @relation("UserMessages", fields: [authorId], references: [id])
  createdAt     DateTime   @default(now())
  isDeleted     Boolean    @default(false)
}

// 6. Historique de Participation
model JamParticipation {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("UserParticipations", fields: [userId], references: [id])
  sessionId     String
  session       JamSession @relation("SessionParticipations", fields: [sessionId], references: [id], onDelete: Cascade)
  joinedAt      DateTime  @default(now())
  leftAt        DateTime?
  role          String    // "HOST" ou "GUEST"
}

// 7. Système d'Amis
model Friend {
  id            String    @id @default(cuid())
  userId1       String
  user1         User      @relation("UserFriends1", fields: [userId1], references: [id])
  userId2       String
  user2         User      @relation("UserFriends2", fields: [userId2], references: [id])
  status        String    // "PENDING", "ACCEPTED"
  createdAt     DateTime  @default(now())

  @@unique([userId1, userId2])
}
