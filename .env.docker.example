# Your Gemini API Key for production use
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube Data API v3 Key (Required for YouTube Search)
# Get yours at https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# The database url is automatically handled in docker-compose.yml
# so you only need to copy this file to `.env` to start onlyjam:
# cp .env.docker.example .env
